<footer class="footer">
	<div class="container footer-grid">
		<!-- Branding Column -->
		<div class="footer-brand-col">
			<a href="/" class="logo">
				<span class="logo-text text-gradient">DTing</span>
			</a>
			<p class="brand-desc">
				Building modern technology, developer infrastructure, and rich utility applications for the next generation.
			</p>
			<div class="social-icons">
				<a href="#" aria-label="Github"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg></a>
				<a href="#" aria-label="Twitter"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a>
				<a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
			</div>
		</div>

		<!-- Services Column -->
		<div class="footer-links-col">
			<h4 class="col-title">Services</h4>
			<ul class="col-links">
				<li><a href="/services/pocketpay">PocketPay Finance</a></li>
				<li><a href="/services/toolkit">Image Toolkit</a></li>
				<li><a href="/services/virelix">Virelix URL Shortener</a></li>
				<li><a href="/services/dtalk">DTalk Chat</a></li>
			</ul>
		</div>

		<!-- Platform Column -->
		<div class="footer-links-col">
			<h4 class="col-title">Platform</h4>
			<ul class="col-links">
				<li><a href="https://auth.dting.online/login" target="_blank" rel="noopener noreferrer">Console Login</a></li>
				<li><a href="https://auth.dting.online/register" target="_blank" rel="noopener noreferrer">Create Account</a></li>
				<li><a href="/#features">Platform Security</a></li>
				<li><a href="/#about">API Status</a></li>
			</ul>
		</div>

		<!-- Contact Column -->
		<div class="footer-links-col">
			<h4 class="col-title">Contact</h4>
			<p class="contact-text">Have questions or want to partner with us?</p>
			<a href="mailto:dting.official@gmail.com" class="contact-email">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
				dting.official@gmail.com
			</a>
		</div>
	</div>

	<!-- Bottom Copyright -->
	<div class="footer-bottom">
		<div class="container footer-bottom-container">
			<p class="copyright">&copy; {new Date().getFullYear()} DTing. All Rights Reserved.</p>
			<div class="footer-bottom-links">
				<a href="#">Privacy Policy</a>
				<a href="#">Terms of Service</a>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: rgba(7, 9, 14, 0.95);
		border-top: 1px solid var(--border-color);
		padding: 5rem 0 2rem 0;
		margin-top: auto;
		position: relative;
		z-index: 10;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1.5fr;
		gap: 4rem;
		margin-bottom: 4rem;
	}

	/* Branding Column */
	.footer-brand-col {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.logo-text {
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: 1.8rem;
		letter-spacing: -0.03em;
	}

	.brand-desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		max-width: 320px;
	}

	.social-icons {
		display: flex;
		gap: 1rem;
	}

	.social-icons a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border-color);
		color: var(--text-secondary);
		transition: all 0.3s ease;
	}

	.social-icons a:hover {
		background: var(--grad-primary);
		color: #07090e;
		transform: translateY(-3px);
		border-color: transparent;
		box-shadow: 0 5px 15px rgba(0, 242, 254, 0.3);
	}

	/* Link Columns */
	.col-title {
		font-family: var(--font-heading);
		font-size: 1.1rem;
		font-weight: 600;
		margin-bottom: 1.75rem;
		position: relative;
		padding-bottom: 0.5rem;
	}

	.col-title::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 30px;
		height: 2px;
		background: var(--grad-primary);
		border-radius: 2px;
	}

	.col-links {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.col-links a {
		color: var(--text-secondary);
		font-size: 0.95rem;
	}

	.col-links a:hover {
		color: var(--text-primary);
		padding-left: 5px;
	}

	/* Contact Column */
	.contact-text {
		color: var(--text-secondary);
		font-size: 0.95rem;
		margin-bottom: 1.25rem;
	}

	.contact-email {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-primary);
		font-weight: 500;
		font-size: 0.95rem;
		transition: color 0.3s ease;
	}

	.contact-email:hover {
		color: var(--accent-cyan);
	}

	/* Footer Bottom */
	.footer-bottom {
		border-top: 1px solid var(--border-color);
		padding-top: 2rem;
	}

	.footer-bottom-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.footer-bottom-links {
		display: flex;
		gap: 1.5rem;
	}

	.footer-bottom-links a:hover {
		color: var(--text-primary);
	}

	/* Responsive Breakpoints */
	@media (max-width: 992px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
		}
	}

	@media (max-width: 576px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.footer-bottom-container {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}
	}
</style>
